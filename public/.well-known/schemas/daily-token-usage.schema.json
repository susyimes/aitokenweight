{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "/.well-known/schemas/daily-token-usage.schema.json",
  "title": "DailyTokenUsage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "date",
    "timezone",
    "provider",
    "handle",
    "totalTokens",
    "source"
  ],
  "properties": {
    "date": {
      "type": "string",
      "format": "date"
    },
    "timezone": {
      "type": "string",
      "default": "Asia/Shanghai"
    },
    "provider": {
      "type": "string"
    },
    "handle": {
      "type": "string",
      "minLength": 1
    },
    "inputTokens": {
      "type": "integer",
      "minimum": 0
    },
    "outputTokens": {
      "type": "integer",
      "minimum": 0
    },
    "cachedTokens": {
      "type": "integer",
      "minimum": 0
    },
    "totalTokens": {
      "type": "integer",
      "minimum": 0
    },
    "whPerThousand": {
      "type": "number",
      "minimum": 0.01,
      "maximum": 10,
      "default": 0.4
    },
    "metricIds": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "string"
      }
    },
    "history": {
      "type": "array",
      "minItems": 1,
      "maxItems": 7,
      "items": {
        "type": "integer",
        "minimum": 0
      }
    },
    "scope": {
      "type": "string",
      "enum": [
        "day",
        "session"
      ],
      "default": "day",
      "description": "day: full-day usage; session: current conversation only (the poster titles itself accordingly)."
    },
    "funLine": {
      "type": "string",
      "maxLength": 48,
      "description": "Optional creative one-liner equating the token volume to something vivid, rendered verbatim under the token count (e.g. ≈ 把《三体》三部曲通读 9 遍). Omit to let the page show its default equivalence."
    },
    "source": {
      "type": "string",
      "enum": [
        "agent_runtime",
        "provider_api",
        "local_log",
        "derived",
        "manual"
      ]
    },
    "usageEvidence": {
      "type": "string",
      "description": "Human-readable evidence for the usage source, such as a runtime usage object, CLI token line, trace id, provider usage query, or the derivation method for a conversation-derived estimate."
    }
  }
}
